# Hugging Face token for gated TabPFN checkpoints such as v2.5.
HF_TOKEN=

# Supported values: v2, v2.5
RECPFN_TABPFN_VERSION=v2

# Set to 1 only when you intentionally want to benchmark larger CPU-only TabPFN runs.
TABPFN_ALLOW_CPU_LARGE_DATASET=0

# Optional development cap for Amazon Reviews 2023 ingestion.
RECPFN_AMAZON_MAX_REVIEWS=20000
